domain.tld {
    route {
        handle /standings_data/* {
            reverse_proxy https://algocode.ru {
                header_up Host algocode.ru
            }
            header {
                Access-Control-Allow-Origin *
                Access-Control-Allow-Methods "GET, OPTIONS"
                Access-Control-Allow-Headers *
            }
        }
        
        handle {
            root * /var/www/standings
            try_files {path} {path}/ index.html
            file_server
        }
}   
